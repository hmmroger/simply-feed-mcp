{
  "name": "simply-feed-mcp",
  "displayName": "Simply Feed MCP Server",
  "description": "A Model Context Protocol (MCP) server for managing and querying RSS/news feeds. This server enables AI assistants to fetch, search, and retrieve information from RSS feeds in real-time.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rss",
    "news-feeds",
    "feed-reader",
    "ai-assistant",
    "news-aggregator"
  ],
  "license": "MIT",
  "author": "hmmroger",
  "homepage": "https://github.com/hmmroger/simply-feed-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmmroger/simply-feed-mcp.git"
  },
  "version": "0.0.6",
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.map"
  ],
  "type": "module",
  "bin": {
    "simply-feed-mcp": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "node generate-version.mjs",
    "build": "npm run check-types && npm run lint && npm run build:tsc",
    "build:tsc": "tsc --project tsconfig.json",
    "watch": "npm-run-all -p watch:*",
    "watch:tsc": "tsc --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "server": "node ./dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.17",
    "@types/yargs": "^17.0.35",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/storage-blob": "^12.31.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "es-toolkit": "^1.45.1",
    "fast-xml-parser": "^5.5.11",
    "mdast-util-from-markdown": "^2.0.3",
    "node-html-markdown": "^1.3.0",
    "openai": "^6.34.0",
    "unist-util-visit": "^5.1.0",
    "uuid": "^11.1.0",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.22.2"
  }
}
